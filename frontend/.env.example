# ── 프론트엔드 환경변수 예시 ────────────────────────────────────────────────
# 이 파일을 복사해서 .env.production 으로 저장한 뒤 값을 채우세요.
# Vercel 배포 시: Vercel 대시보드 → Project Settings → Environment Variables 에서 입력

# 백엔드 API 서버 주소 (끝에 슬래시 없이)
# 예: https://ppt-to-word-api.onrender.com
REACT_APP_API_URL=https://your-backend.onrender.com
