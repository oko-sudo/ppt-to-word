# ── 백엔드 환경변수 예시 ──────────────────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
# Render 배포 시: Render 대시보드의 Environment 탭에서 직접 입력

# 허용할 프론트엔드 도메인 (콤마로 구분, 공백 없이)
# 예: https://my-app.vercel.app 또는 https://my-app.vercel.app,https://my-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 세션 만료 시간 (분)
SESSION_EXPIRE_MINUTES=60

# 업로드 최대 파일 크기 (MB)
MAX_FILE_SIZE_MB=50
